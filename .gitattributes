# Normalize line endings for all text files
* text=auto

# Force LF for code and config files (consistent on all platforms)
*.py   text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.env  text eol=lf
.env.example text eol=lf
.gitignore   text eol=lf
