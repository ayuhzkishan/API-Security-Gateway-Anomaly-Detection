# ============================================================
# API Security Gateway — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# Required: JWT signing secret (min 32 chars, use a random value)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-strong-256-bit-random-secret
